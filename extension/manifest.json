{
  "manifest_version": 3,
  "name": "ChainGuard Protocol",
  "version": "1.0.0",
  "description": "One-click blockchain malware defense. Stops ransomware droppers, wallet drainers, and credential stealers.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "notifications",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://*.infura.io/*",
    "https://*.alchemy.com/*",
    "https://*.quicknode.io/*",
    "https://*.helius-rpc.com/*",
    "http://localhost:8000/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
